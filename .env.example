# Supabase Configuration (Optional - for PDF parsing fallback)
# If you want to use Supabase for PDF parsing, create a .env file and add these variables
# Get these values from your Supabase project dashboard: https://app.supabase.com

VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Note: PDF files will first try client-side parsing with pdf-parse
# If that fails, it will fall back to Supabase edge function (requires configuration above)
# TXT and DOCX files work without Supabase configuration
