PORT=8000
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173,http://127.0.0.1:8080,http://127.0.0.1:5173
BACKEND_MODE=active

# Enable strict token verification against Supabase auth endpoint.
REQUIRE_SUPABASE_AUTH=false
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Optional: service role key for logging extraction metadata into Supabase table.
SUPABASE_SERVICE_ROLE_KEY=
